{
  "name": "tension-pool-2",
  "packageManager": "pnpm@8.7.5",
  "version": "0.3.3",
  "description": "Tension Pool 2 is a Foundry (Re)Implementation and Evolution of the Angry GM's idea of Time Pools/Tension Pools",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "authors": [
    {
      "name": "sagarc03",
      "url": "https://github.com/sagarc03"
    }
  ],
  "repository": "sagarc03/tension-pool-2",
  "license": "MIT",
  "foundry": {
    "id": "tension-pool-2",
    "title": "Tension Pool 2",
    "compatibility": {
      "minimum": "13",
      "verified": "13"
    },
    "socket": true,
    "languages": [
      {
        "lang": "en",
        "name": "English",
        "path": "lang/en.json"
      }
    ],
    "relationships": {
      "optional": [
        {
          "id": "quench",
          "type": "module",
          "compatibility": {
            "minimum": "0.10.0"
          }
        }
      ]
    }
  },
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "13.346.0-beta.20251209192131",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
